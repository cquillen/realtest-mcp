// Simple Mean Reversion Strategy using RSI(2)
// Category: Mean Reversion

Settings:
  StartDate: 2010-01-01
  EndDate: 2023-12-31
  InitialCapital: 100000
  Commission: 0.005

Strategy MeanReversion:
  MaxPositions: 10
  PositionSize: 10%

  EntrySetup: RSI(2) < 10
  Entry: Open

  ExitRule: RSI(2) > 90
  ExitStop: Entry * 0.92

  SetupScore: -RSI(2)
